# ---------------------------------------------------------------------------
# Optional configuration. Leave unset for normal root-domain deployments.
# ---------------------------------------------------------------------------

# Deploy under a subpath (e.g. when proxied from another domain).
# Example: serve the app at https://example.com/labs/simpack
# NEXT_PUBLIC_BASE_PATH=/labs/simpack

# Override the static-asset prefix. Defaults to NEXT_PUBLIC_BASE_PATH.
# Useful when /_next/static is fronted by a CDN.
# NEXT_PUBLIC_ASSET_PREFIX=https://cdn.example.com/labs/simpack

# Public site URL used for absolute metadata (OG/Twitter cards, canonical URLs).
# If unset, Vercel's VERCEL_URL is used automatically on Vercel deployments.
# NEXT_PUBLIC_SITE_URL=https://simpack-tau.vercel.app
